    {
      "name": "AI - Unsupported question fallback",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{aliceToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/assistant/questions",
          "host": ["{{baseUrl}}"],
          "path": ["assistant", "questions"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"Please delete all my events now\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.expect(body.answer).to.be.a('string').and.not.empty;",
              "",
              "// In strict fallback mode this should be exact; with external LLM configured",
              "// this may still be a safe refusal text, so we keep this assertion tolerant.",
              "const fallback = pm.collectionVariables.get('fallbackMessage');",
              "pm.test('Fallback or safe refusal', function () {",
              "  pm.expect(",
              "    body.answer === fallback || /sorry|cannot|can.t|didn.t understand/i.test(body.answer)",
              "  ).to.equal(true);",
              "});"
            ]
          }
        }
      ]
