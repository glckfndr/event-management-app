{
  "info": {
    "name": "Event Management - AI Assistant API",
    "_postman_id": "1c7bace4-bf44-48ce-9c4b-1e1f7f4e2847",
    "description": "Postman collection for issue #11: read-only AI assistant endpoint tests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "aliceEmail", "value": "alice@example.com" },
    { "key": "alicePassword", "value": "Password123!" },
    { "key": "bobEmail", "value": "bob@example.com" },
    { "key": "bobPassword", "value": "Password123!" },
    { "key": "aliceToken", "value": "" },
    { "key": "bobToken", "value": "" },
    { "key": "eventId", "value": "" },
    { "key": "eventTitle", "value": "AI Postman Tagged Event" },
    {
      "key": "fallbackMessage",
      "value": "Sorry, I didn’t understand that. Please try rephrasing your question."
    }
  ],
  "item": [
    {
      "name": "Auth - Login Alice (set aliceToken)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{aliceEmail}}\",\n  \"password\": \"{{alicePassword}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "const token = body.accessToken || body.token;",
              "pm.expect(token).to.be.a('string').and.not.empty;",
              "pm.collectionVariables.set('aliceToken', token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Login Bob (set bobToken)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
