              "pm.expect(token).to.be.a('string').and.not.empty;",
              "pm.collectionVariables.set('bobToken', token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Events - Create tagged event for assistant scenarios",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{aliceToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/events",
          "host": ["{{baseUrl}}"],
          "path": ["events"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"{{eventTitle}}\",\n  \"description\": \"Created by Postman AI collection\",\n  \"eventDate\": \"2027-03-20T12:00:00.000Z\",\n  \"location\": \"Kyiv\",\n  \"visibility\": \"public\",\n  \"tags\": [\"tech\", \"backend\"]\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.expect(body.id).to.be.a('string').and.not.empty;",
              "pm.collectionVariables.set('eventId', body.id);"
            ]
          }
        }
      ]
    },
