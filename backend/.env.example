PORT=3001
FRONTEND_URL=http://localhost:8090,http://127.0.0.1:8090
ENABLE_SWAGGER=true
FORBID_NON_WHITELISTED=true
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1h
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=event_user
DB_PASSWORD=your_strong_password_here
DB_DATABASE=event_management
DB_SYNCHRONIZE=false

# Optional AI provider config (for /assistant/questions endpoint)
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
# AI_BASE_URL= (optional custom OpenAI-compatible base URL)
